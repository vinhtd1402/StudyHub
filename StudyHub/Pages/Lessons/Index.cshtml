@page
@model StudyHub.Pages_Lessons.IndexModel

@{
    ViewData["Title"] = "Lessons";
}

<h1>Lessons</h1>

<div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-3">

    <form method="get" class="row g-2 flex-grow-1">

        <div class="col-md-5">
            <input asp-for="SearchTerm"
                   class="form-control"
                   placeholder="Search lessons, content, or course" />
        </div>

        <div class="col-md-4">
            <select asp-for="CourseId"
                    asp-items="Model.CourseOptions"
                    class="form-select">
                <option value="">All courses</option>
            </select>
        </div>

        <div class="col-md-3 d-flex gap-2">
            <button type="submit" class="btn btn-primary">
                Search
            </button>

            <a asp-page="./Index" class="btn btn-outline-secondary">
                Clear
            </a>
        </div>

    </form>

    @if (User.IsInRole("Teacher"))
    {
        <a asp-page="Create" class="btn btn-primary">
            Create New
        </a>
    }

</div>

@if (Model.Lessons.Any())
{
    <table class="table table-bordered table-hover">

        <thead class="table-dark">
            <tr>
                <th>
                    Title
                </th>

                <th>
                    Content
                </th>

                <th>
                    Course
                </th>

                <th width="220">
                    Actions
                </th>
            </tr>
        </thead>

        <tbody>

            @foreach (var item in Model.Lessons)
            {
                <tr>

                    <td>
                        @item.Title
                    </td>

                    <td>
                        @(item.Content?.Length > 80
                            ? item.Content.Substring(0, 80) + "..."
                            : item.Content)
                    </td>

                    <td>
                        @item.Course?.Title
                    </td>

                    <td>

                        <a asp-page="./Details"
                               asp-route-id="@item.Id"
                               class="btn btn-sm btn-info">

                            Details

                        </a>

                        @if (User.IsInRole("Teacher"))
                        {
                            <a asp-page="./Edit"
                                   asp-route-id="@item.Id"
                                   class="btn btn-sm btn-warning">

                                Edit

                            </a>

                            <a asp-page="./Delete"
                                   asp-route-id="@item.Id"
                                   class="btn btn-sm btn-danger">

                                Delete

                            </a>
                        }

                    </td>

                </tr>
            }

        </tbody>

    </table>
}
else
{
    <div class="alert alert-info">

        No lessons match your filters.

    </div>
}

@page
@model StudyHub.Pages_Lessons.EditModel

@{
    ViewData["Title"] = "Edit Lesson";
}

<h1>Edit Lesson</h1>

<h4>Lesson</h4>
<hr />

<div class="row">
    <div class="col-md-8">

        <form method="post">

            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <input type="hidden" asp-for="Lesson.Id" />

            <!-- Title -->
            <div class="mb-3">
                <label asp-for="Lesson.Title" class="form-label"></label>

                <span class="text-danger">*</span>

                <input asp-for="Lesson.Title"
                       class="form-control"
                       aria-required="true" />

                <span asp-validation-for="Lesson.Title"
                      class="text-danger"></span>
            </div>

            <!-- Content -->
            <div class="mb-3">

                <label asp-for="Lesson.Content"
                       class="form-label"></label>

                <textarea asp-for="Lesson.Content"
                          class="form-control"
                              rows="10">
                </textarea>

                    <span asp-validation-for="Lesson.Content"
                          class="text-danger"></span>

                </div>

                <!-- Youtube URL -->
                <div class="mb-3">

                    <label asp-for="Lesson.YoutubeUrl"
                           class="form-label"></label>

                    <input asp-for="Lesson.YoutubeUrl"
                           class="form-control"
                           placeholder="https://youtube.com/watch?v=..." />

                    <span asp-validation-for="Lesson.YoutubeUrl"
                          class="text-danger"></span>

                </div>

                <!-- Course -->
                <div class="mb-3">

                    <label asp-for="Lesson.CourseId"
                           class="form-label"></label>

                    <select asp-for="Lesson.CourseId"
                            class="form-control"
                            asp-items="ViewBag.CourseId">
                    </select>

                    <span asp-validation-for="Lesson.CourseId"
                          class="text-danger"></span>

                </div>

                <!-- Buttons -->
                <div class="mt-3">

                    <input type="submit"
                           value="Save"
                           class="btn btn-primary" />

                    <a asp-page="./Index"
                           class="btn btn-secondary">
                        Back to List
                    </a>

                </div>

            </form>

        </div>
    </div>

    @section Scripts {
        @{
            await Html.RenderPartialAsync("_ValidationScriptsPartial");
        }
    }
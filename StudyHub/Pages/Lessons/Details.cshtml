@page
@model StudyHub.Pages_Lessons.DetailsModel
@using System.Linq
@{
    ViewData["Title"] = "Lesson Details";
}

<div class="container mt-4">

    <!-- TITLE -->

    <h1>@Model.Lesson.Title</h1>

    <hr />

    <!-- LESSON CONTENT -->

    <div class="card mb-4">

        <div class="card-body">

            <h4>Lesson Content</h4>

            <p style="white-space: pre-line">
                @Model.Lesson.Content
            </p>

        </div>

    </div>

    <!-- YOUTUBE VIDEO -->
    @if (!string.IsNullOrEmpty(Model.Lesson.YoutubeUrl))
    {
        var videoUrl = Model.Lesson.YoutubeUrl;

        if (videoUrl.Contains("watch?v="))
        {
            videoUrl = videoUrl.Replace("watch?v=", "embed/");
        }
        else if (videoUrl.Contains("youtu.be/"))
        {
            var videoId = videoUrl.Split('/').Last();
            videoUrl = $"https://www.youtube.com/embed/{videoId}";
        }

        <div class="card shadow-sm mb-4">
            <div class="card-body">

                <h4>Video</h4>

                <iframe width="100%"
                        height="500"
                        src="@videoUrl"
                        frameborder="0"
                        allowfullscreen>
                </iframe>

            </div>
        </div>
    }

    <!-- QUIZ SECTION -->

    <div class="mt-4">

        <div class="d-flex justify-content-between align-items-center mb-3">

            <h3>Quizzes</h3>

            @if (User.IsInRole("Teacher"))
            {
                <a asp-page="/Quizzes/Create"
                       asp-route-lessonId="@Model.Lesson.Id"
                       class="btn btn-success">

                    Create Quiz

                </a>
            }

        </div>

        @if (Model.Lesson.Quizzes != null
            && Model.Lesson.Quizzes.Any())
        {
            <ul class="list-group">

                @foreach (var quiz in Model.Lesson.Quizzes)
                {
                    <li class="list-group-item d-flex justify-content-between align-items-center">

                        <span>@quiz.Title</span>

                        @if (User.IsInRole("Student"))
                        {
                            <a class="btn btn-sm btn-primary"
                                   asp-page="/Quizzes/Take"
                                   asp-route-id="@quiz.Id">

                                Start

                            </a>
                        }
                        else if (User.IsInRole("Teacher"))
                        {
                            <a class="btn btn-sm btn-info"
                                   asp-page="/Quizzes/Results"
                                   asp-route-quizId="@quiz.Id">

                                View Results

                            </a>
                        }

                    </li>
                }

            </ul>
        }
        else
        {
            <p class="text-muted">
                No quiz available for this lesson.
            </p>
        }

    </div>

    <hr />

    <!-- STUDENT RESULTS -->
    @if (User.IsInRole("Teacher"))
    {
        <div class="mt-4">

            <h3>Student Results</h3>

            @if (Model.QuizResults != null
                && Model.QuizResults.Any())
            {
                <table class="table table-bordered">

                    <thead>
                        <tr>
                            <th>Student</th>
                            <th>Score</th>
                        </tr>
                    </thead>

                    <tbody>

                        @foreach (var r in Model.QuizResults)
                        {
                            <tr>
                                <td>@r.StudentName</td>
                                <td>@r.Score</td>
                            </tr>
                        }

                    </tbody>

                </table>
            }
            else
            {
                <p class="text-muted">
                    No results yet.
                </p>
            }

        </div>

        <hr />
    }

    <!-- NAVIGATION -->

    <div class="d-flex justify-content-between mt-4">

        <div>

            @if (Model.PreviousLesson != null)
            {
                <a class="btn btn-outline-primary"
                       asp-page="/Lessons/Details"
                       asp-route-id="@Model.PreviousLesson.Id">

                    ← Previous

                </a>
            }

        </div>

        <div class="d-flex gap-2">

            @if (User.IsInRole("Student"))
            {
                <form method="post"
                      asp-page-handler="Complete"
                      asp-route-id="@Model.Lesson.Id">

                    <button type="submit"
                            class="btn btn-success">

                        Mark as Completed

                    </button>

                </form>
            }

            @if (Model.NextLesson != null)
            {
                <a class="btn btn-primary"
                       asp-page="/Lessons/Details"
                       asp-route-id="@Model.NextLesson.Id">

                    Next →

                </a>
            }

        </div>

    </div>

</div>

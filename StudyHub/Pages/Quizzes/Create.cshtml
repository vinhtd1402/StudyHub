@page
@model StudyHub.Pages.Quizzes.CreateModel

<div class="container mt-4">

    <h2>Create Quiz</h2>

    <form method="post">

        <input type="hidden"
               asp-for="Quiz.LessonId" />

        <div class="mb-3">

            <label class="form-label">
                Quiz Title
            </label>

            <input asp-for="Quiz.Title"
                   class="form-control" />

        </div>

        <div class="mb-3">

            <label class="form-label">
                Passing Score (%)
            </label>

            <input asp-for="Quiz.PassingScorePercent"
                   type="number"
                   min="0"
                   max="100"
                   class="form-control" />

        </div>

        <div class="mb-3">

            <label class="form-label">
                Number Of Questions
            </label>

            <input asp-for="Quiz.QuestionCount"
                   type="number"
                   min="1"
                   class="form-control" />

        </div>

        <button type="submit"
                class="btn btn-primary">

            Next

        </button>

    </form>

</div>

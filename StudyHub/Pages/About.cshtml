@page
@model AboutModel

@{
    ViewData["Title"] = "About";
}

<div class="container mt-5">

    <div class="text-center mb-5">

        <h1 class="display-4 fw-bold">
            About StudyHub
        </h1>

        <p class="lead text-muted">
            A modern online learning platform for students and teachers.
        </p>

    </div>

    <div class="row g-4">

        <div class="col-md-4">

            <div class="card shadow-sm border-0 h-100">

                <div class="card-body text-center p-4">

                    <div class="display-4 mb-3">
                        📚
                    </div>

                    <h4 class="fw-bold">
                        Online Courses
                    </h4>

                    <p class="text-muted">
                        Students can access structured lessons and
                        educational resources anytime.
                    </p>

                </div>

            </div>

        </div>

        <div class="col-md-4">

            <div class="card shadow-sm border-0 h-100">

                <div class="card-body text-center p-4">

                    <div class="display-4 mb-3">
                        🧠
                    </div>

                    <h4 class="fw-bold">
                        Interactive Learning
                    </h4>

                    <p class="text-muted">
                        Quizzes and progress tracking help students
                        learn more effectively.
                    </p>

                </div>

            </div>

        </div>

        <div class="col-md-4">

            <div class="card shadow-sm border-0 h-100">

                <div class="card-body text-center p-4">

                    <div class="display-4 mb-3">
                        🚀
                    </div>

                    <h4 class="fw-bold">
                        Skill Development
                    </h4>

                    <p class="text-muted">
                        StudyHub helps learners improve practical
                        skills through real learning experiences.
                    </p>

                </div>

            </div>

        </div>

    </div>

    <div class="mt-5">

        <div class="card bg-dark text-white border-0 shadow">

            <div class="card-body p-5 text-center">

                <h2 class="fw-bold mb-3">
                    Our Mission
                </h2>

                <p class="lead mb-0">
                    To make learning simple, interactive, and accessible
                    for everyone through technology.
                </p>

            </div>

        </div>

    </div>

</div>
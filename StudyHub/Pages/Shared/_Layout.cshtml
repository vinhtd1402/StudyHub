<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - StudyHub</title>

    <link rel="stylesheet"
          href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <link rel="stylesheet"
          href="~/css/site.css"
          asp-append-version="true" />

    <link rel="stylesheet"
          href="~/StudyHub.styles.css"
          asp-append-version="true" />

    <link rel="preconnect"
          href="https://fonts.googleapis.com">

    <link rel="preconnect"
          href="https://fonts.gstatic.com"
          crossorigin>

    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap"
          rel="stylesheet">
</head>

<body>

    <header>

        <nav class="navbar navbar-expand-lg navbar-dark shadow-sm">

            <div class="container">

                <a class="navbar-brand fw-bold"
                       asp-area=""
                       asp-page="/Index">

                    StudyHub

                </a>

                <button class="navbar-toggler"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#navbarContent">

                    <span class="navbar-toggler-icon"></span>

                </button>

                <div class="collapse navbar-collapse"
                     id="navbarContent">

                    <ul class="navbar-nav me-auto">

                        <li class="nav-item">
                            <a class="nav-link"
                                   asp-page="/Index">

                                Home

                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link"
                                   asp-page="/Courses/Index">

                                Courses

                            </a>
                        </li>

                        @if (!User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link"
                                   asp-page="/Courses/MyCourses">

                                    My Courses

                                </a>
                            </li>
                        }

                        <li class="nav-item">
                            <a class="nav-link"
                                   asp-page="/Lessons/Index">

                                Lessons

                            </a>
                        </li>

                        @if (User.IsInRole("Student") || User.IsInRole("Teacher"))
                        {
                            <li class="nav-item">
                                <a class="nav-link"
                                   asp-page="/Credits/Index">

                                    My Credit

                                </a>
                            </li>
                        }

                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link"
                                   asp-page="/Admin/Teachers">

                                    Teachers

                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link"
                                   asp-page="/Admin/Credits">

                                    Credit Approvals

                                </a>
                            </li>
                        }

                        <li class="nav-item">
                            <a class="nav-link"
                                   asp-page="/About">

                                About

                            </a>
                        </li>

                    </ul>

                    <partial name="_LoginPartial" />

                </div>

            </div>

        </nav>

    </header>

    <main>

        @RenderBody()

    </main>

    <footer class="footer text-white mt-5">

        <div class="container d-flex justify-content-between align-items-center">

            <span>
                © 2026 - StudyHub
            </span>

            <span>
                Learn Anywhere • Anytime
            </span>

        </div>

    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script src="~/js/site.js"
            asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>

@page
@model IndexModel

@{
    ViewData["Title"] = "Home";
}

<div class="container-fluid p-0">

    <!-- HERO SECTION -->

    <section class="bg-dark text-white py-5">

        <div class="container">

            <div class="row align-items-center">

                <div class="col-lg-6">

                    <h1 class="display-4 fw-bold mb-3">
                        Learn Without Limits
                    </h1>

                    <p class="lead text-light mb-4">
                        StudyHub is an online learning platform where students
                        can learn programming, technology, and practical skills
                        through interactive lessons and quizzes.
                    </p>

                    <div class="d-flex gap-3">

                        <a asp-page="/Courses/Index"
                               class="btn btn-primary btn-lg">

                            Explore Courses

                        </a>

                        <a asp-page="/Courses/MyCourses"
                               class="btn btn-outline-light btn-lg">

                            My Courses

                        </a>

                    </div>

                </div>

                <div class="col-lg-6 text-center">

                    <img src="https://images.unsplash.com/photo-1516321318423-f06f85e504b3?q=80&w=1200&auto=format&fit=crop"
                         class="img-fluid rounded shadow-lg"
                         style="max-height:400px; object-fit:cover;" />

                </div>

            </div>

        </div>

    </section>

    <!-- FEATURES -->

    <section class="py-5 bg-light">

        <div class="container">

            <div class="text-center mb-5">

                <h2 class="fw-bold">
                    Why Choose StudyHub?
                </h2>

                <p class="text-muted">
                    Everything you need to learn effectively.
                </p>

            </div>

            <div class="row g-4">

                <div class="col-md-4">

                    <div class="card border-0 shadow-sm h-100">

                        <div class="card-body text-center p-4">

                            <div class="display-5 mb-3">
                                📚
                            </div>

                            <h4 class="fw-bold">
                                Quality Courses
                            </h4>

                            <p class="text-muted">
                                Learn through structured lessons designed
                                for beginners and advanced students.
                            </p>

                        </div>

                    </div>

                </div>

                <div class="col-md-4">

                    <div class="card border-0 shadow-sm h-100">

                        <div class="card-body text-center p-4">

                            <div class="display-5 mb-3">
                                🧠
                            </div>

                            <h4 class="fw-bold">
                                Interactive Quizzes
                            </h4>

                            <p class="text-muted">
                                Test your understanding after every lesson
                                with quizzes and instant feedback.
                            </p>

                        </div>

                    </div>

                </div>

                <div class="col-md-4">

                    <div class="card border-0 shadow-sm h-100">

                        <div class="card-body text-center p-4">

                            <div class="display-5 mb-3">
                                🚀
                            </div>

                            <h4 class="fw-bold">
                                Track Progress
                            </h4>

                            <p class="text-muted">
                                Monitor your learning progress and complete
                                courses step by step.
                            </p>

                        </div>

                    </div>

                </div>

            </div>

        </div>

    </section>

    <!-- POPULAR COURSES -->

    <section class="py-5">

        <div class="container">

            <div class="d-flex justify-content-between align-items-center mb-4">

                <div>

                    <h2 class="fw-bold mb-1">
                        Popular Courses
                    </h2>

                    <p class="text-muted mb-0">
                        Courses with the most students enrolled.
                    </p>

                </div>

                <a asp-page="/Courses/Index"
                       class="btn btn-outline-primary">

                    View All

                </a>

            </div>

            <div class="row g-4">

                @foreach (var course in Model.PopularCourses)
                {
                    <div class="col-md-6 col-lg-4">

                        <div class="card border-0 shadow-sm h-100">

                            <div class="card-body d-flex flex-column">

                                <h4 class="fw-bold mb-3">
                                    @course.Title
                                </h4>

                                <p class="text-muted flex-grow-1">
                                    @course.Description
                                </p>

                                <div class="mb-3">

                                    <small class="text-secondary">
                                        Instructor:
                                        @course.Teacher?.FullName
                                    </small>

                                </div>

                                <div class="d-flex justify-content-between align-items-center">

                                    <span class="badge bg-primary fs-6">
                                        @course.Enrollments.Count Students
                                    </span>

                                    <a asp-page="/Courses/Details"
                                           asp-route-id="@course.Id"
                                           class="btn btn-sm btn-dark">

                                        View Course

                                    </a>

                                </div>

                            </div>

                        </div>

                    </div>
                }

            </div>

        </div>

    </section>

    <!-- CALL TO ACTION -->

    <section class="bg-primary text-white py-5 mt-5">

        <div class="container text-center">

            <h2 class="fw-bold mb-3">
                Start Learning Today
            </h2>

            <p class="lead mb-4">
                Join StudyHub and improve your skills with online learning.
            </p>

            <a asp-page="/Courses/Index"
                   class="btn btn-light btn-lg">

                Browse Courses

            </a>

        </div>

    </section>

</div>
@page
@model StudyHub.Pages_Courses.MyCoursesModel

@{
    ViewData["Title"] = "My Courses";
}

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>
            <h1 class="fw-bold mb-1">
                @(User.IsInRole("Teacher")
                    ? "My Teaching Courses"
                    : "My Enrolled Courses")
            </h1>

            <p class="text-muted mb-0">
                Manage and continue your learning journey.
            </p>
        </div>

    </div>

    <form method="get" class="row g-2 mb-4">

        <div class="col-md-6">
            <input asp-for="SearchTerm"
                   class="form-control"
                   placeholder="Search your courses or instructors" />
        </div>

        @if (User.IsInRole("Student"))
        {
            <div class="col-md-3">
                <select asp-for="StatusFilter"
                        class="form-select">
                    <option value="all">All progress</option>
                    <option value="not-started">Not started</option>
                    <option value="in-progress">In progress</option>
                    <option value="completed">Completed</option>
                </select>
            </div>
        }

        <div class="col-md-3 d-flex gap-2">
            <button type="submit" class="btn btn-primary">
                Search
            </button>

            <a asp-page="./MyCourses" class="btn btn-outline-secondary">
                Clear
            </a>
        </div>

    </form>

    @if (!Model.Courses.Any())
    {
        <div class="card shadow-sm border-0">

            <div class="card-body text-center p-5">

                <h4 class="mb-3">
                    No Courses Yet
                </h4>

                <p class="text-muted">
                    You have not enrolled or created any courses yet.
                </p>

                <a asp-page="/Courses/Index"
                       class="btn btn-primary mt-2">

                    Browse Courses

                </a>

            </div>

        </div>
    }
    else
    {
        <div class="row">

            @foreach (var course in Model.Courses)
            {
                var total = Model.TotalLessonsCount.ContainsKey(course.Id)
                    ? Model.TotalLessonsCount[course.Id]
                    : 0;

                var completed = Model.CompletedLessonsCount.ContainsKey(course.Id)
                    ? Model.CompletedLessonsCount[course.Id]
                    : 0;

                var percent = total == 0
                    ? 0
                    : (completed * 100 / total);

                <div class="col-md-6 col-lg-4 mb-4">

                    <div class="card h-100 shadow-sm border-0">

                        <div class="card-body d-flex flex-column">

                            <div class="d-flex justify-content-between align-items-start mb-2">

                                <h4 class="card-title fw-bold">
                                    @course.Title
                                </h4>

                                @if (User.IsInRole("Student")
                               && total > 0
                               && completed == total)
                                {
                                    <span class="badge bg-success">
                                        Completed
                                    </span>
                                }

                            </div>

                            <p class="text-muted flex-grow-1">
                                @course.Description
                            </p>

                            <div class="mb-3">

                                <small class="text-secondary">
                                    Instructor:
                                    @course.Teacher?.FullName
                                </small>

                            </div>

                            @if (User.IsInRole("Student"))
                            {
                                <div class="mb-2">

                                    <div class="d-flex justify-content-between">

                                        <small class="fw-semibold">
                                            Progress
                                        </small>

                                        <small>
                                            @completed / @total Lessons
                                        </small>

                                    </div>

                                    <div class="progress mt-2"
                                         style="height:10px;">

                                        <div class="progress-bar progress-bar-striped"
                                             role="progressbar"
                                             style="width:@percent%">
                                        </div>

                                    </div>

                                </div>
                            }

                            <div class="mt-4 d-flex gap-2">

                                <a asp-page="/Courses/Details"
                                       asp-route-id="@course.Id"
                                       class="btn btn-outline-dark flex-fill">

                                    View

                                </a>

                                @if (User.IsInRole("Student"))
                                {
                                    <a asp-page-handler="Continue"
                                           asp-route-id="@course.Id"
                                           class="btn btn-primary flex-fill">

                                        Continue

                                    </a>
                                }

                                @if (User.IsInRole("Teacher"))
                                {
                                    <a asp-page="/Courses/Details"
                                           asp-route-id="@course.Id"
                                           class="btn btn-info text-white flex-fill">

                                        Students

                                    </a>
                                }

                            </div>

                        </div>

                    </div>

                </div>
            }

        </div>
    }

</div>

@page
@model StudyHub.Pages_Courses.MyCoursesModel

@{
    ViewData["Title"] = "My Courses";
}

<h1>My Courses</h1>

@if (Model.Courses.Any())
{
    <div class="list-group">
        @foreach (var course in Model.Courses)
        {
            var total = Model.TotalLessonsCount[course.Id];
            var completed = Model.CompletedLessonsCount[course.Id];
            var percent = total == 0 ? 0 : completed * 100 / total;

            <div class="list-group-item">

                <div class="d-flex justify-content-between align-items-center">
                    <h5>@course.Title</h5>

                    @if (Model.TotalLessonsCount[course.Id] > 0 &&
                         Model.CompletedLessonsCount[course.Id] == Model.TotalLessonsCount[course.Id])
                    {
                        <span class="badge bg-success">Completed</span>
                    }
                </div>

                <p>@course.Description</p>
                <small>Teacher: @course.Teacher.Email</small>

                <div class="mt-2">
                    <small class="text-success">
                        Progress: @completed / @total lessons completed
                    </small>
                </div>

                <div class="progress mt-2">
                    <div class="progress-bar"
                         role="progressbar"
                         style="width:@percent%">
                        @percent%
                    </div>
                </div>

                <div class="mt-3 d-flex gap-2">
                    <a asp-page="/Courses/Details"
                           asp-route-id="@course.Id"
                           class="btn btn-outline-secondary">
                        View Course
                    </a>

                    <a asp-page-handler="Continue"
                           asp-route-id="@course.Id"
                           class="btn btn-primary">
                        Continue Learning
                    </a>
                </div>
            </div>
        }
    </div>
}
else
{
    <p>You have not enrolled in any courses yet.</p>
}
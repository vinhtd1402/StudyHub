@page
@model StudyHub.Pages_Courses.DetailsModel

@{
    ViewData["Title"] = "Course Details";
}

<h1 class="mb-3">Course Details</h1>

<div class="card mb-4">
    <div class="card-body">
        <h4 class="card-title">@Model.Course.Title</h4>
        <p class="card-text">@Model.Course.Description</p>

        <p class="mb-1">
            <strong>Teacher:</strong> @Model.Course.Teacher.Email
        </p>
    </div>
</div>

<h4>Lessons</h4>

@if (Model.Course.Lessons?.Any() == true)
{
    <ul class="list-group mb-4">
        @foreach (var lesson in Model.Course.Lessons)
        {
            <li class="list-group-item d-flex justify-content-between align-items-center">
                <span>@lesson.Title</span>

                <a class="btn btn-sm btn-outline-primary"
                       asp-page="/Lessons/Details"
                       asp-route-id="@lesson.Id">
                    View
                </a>
            </li>
        }
    </ul>
}
else
{
    <div class="alert alert-warning">
        No lessons available.
    </div>
}

@* ===== ACTION BUTTONS ===== *@
@if (User.Identity?.IsAuthenticated == true)
{
    <div class="d-flex gap-2 mb-4">

        @* ===== STUDENT ===== *@
        @if (User.IsInRole("Student"))
        {
            @if (Model.IsEnrolled)
            {
                @* Continue learning *@
                @if (Model.Course.Lessons?.Any() == true)
                {
                    <a class="btn btn-primary"
                           asp-page="/Lessons/Details"
                           asp-route-id="@Model.Course.Lessons.First().Id">
                        Continue Learning
                    </a>
                }

                <form method="post"
                      asp-page-handler="Unenroll"
                      asp-route-id="@Model.Course.Id">
                    <button type="submit" class="btn btn-danger">
                        Unenroll
                    </button>
                </form>
            }
            else
            {
                <form method="post"
                      asp-page-handler="Enroll"
                      asp-route-id="@Model.Course.Id">
                    <button type="submit" class="btn btn-success">
                        Enroll
                    </button>
                </form>
            }
        }

        @* ===== TEACHER ===== *@
        @if (User.IsInRole("Teacher") && Model.Course.TeacherId == User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value)
        {
            <a class="btn btn-outline-secondary"
                   asp-page="./Edit"
                   asp-route-id="@Model.Course.Id">
                Edit Course
            </a>
        }

    </div>
}

<div class="mt-4">
    <a asp-page="./Index">← Back to Courses</a>
</div>
@if (User.IsInRole("Teacher"))
{
    <hr />
    <h4>Enrolled Students</h4>

    <p>Total: @Model.EnrolledStudents.Count</p> <!-- debug -->
    @if (!Model.EnrolledStudents.Any())
    {
        <div class="alert alert-info">
            No students enrolled yet.
        </div>
    }
    else
    {
        <ul class="list-group">
            @foreach (var student in Model.EnrolledStudents)
            {
                <li class="list-group-item">
                    <strong>@student.FullName</strong> - @student.Email
                </li>
            }
        </ul>
    }
}
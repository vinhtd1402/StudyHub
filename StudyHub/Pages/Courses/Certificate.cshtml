@page
@model StudyHub.Pages.Courses.CertificateModel

@{
    ViewData["Title"] = "Certificate";
}

<div class="text-center mt-5 border p-5 shadow">
    <h1>Certificate of Completion</h1>

    <p>This certifies that</p>
    <h3>@User.Identity!.Name</h3>

    <p>has successfully completed</p>
    <h2>@Model.Course.Title</h2>

    <p>Date: @DateTime.Now.ToShortDateString()</p>
</div>

<div class="mt-3 text-center">
    <a asp-page="/Courses/MyCourses" class="btn btn-secondary">
        Back to My Courses
    </a>
</div>
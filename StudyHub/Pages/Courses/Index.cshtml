@page
@model StudyHub.Pages_Courses.IndexModel

@{
    ViewData["Title"] = "Courses";
}

<h1>Courses</h1>

<div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-3">

    <form method="get" class="row g-2 flex-grow-1">

        <div class="col-md-5">
            <input asp-for="SearchTerm"
                   class="form-control"
                   placeholder="Search courses, descriptions, or teachers" />
        </div>

        <div class="col-md-4">
            <select asp-for="TeacherId"
                    asp-items="Model.TeacherOptions"
                    class="form-select">
                <option value="">All teachers</option>
            </select>
        </div>

        <div class="col-md-3 d-flex gap-2">
            <button type="submit" class="btn btn-primary">
                Search
            </button>

            <a asp-page="./Index" class="btn btn-outline-secondary">
                Clear
            </a>
        </div>

    </form>

    @if (User.IsInRole("Teacher"))
    {
        <a asp-page="Create" class="btn btn-primary">
            Create New
        </a>
    }

</div>

@if (Model.Course.Any())
{
    <table class="table">
        <thead>
            <tr>
                <th>Title</th>
                <th>Description</th>
                <th>Teacher</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Course)
            {
                <tr>
                    <td>@item.Title</td>
                    <td>@item.Description</td>
                    <td>@(string.IsNullOrWhiteSpace(item.Teacher?.FullName) ? item.Teacher?.Email : item.Teacher.FullName)</td>

                    <td>
                        <a asp-page="./Details" asp-route-id="@item.Id">View</a>

                        @if (User.IsInRole("Teacher"))
                        {
                            <span> | </span>
                            <a asp-page="./Edit" asp-route-id="@item.Id">Edit</a>

                            <span> | </span>
                            <a asp-page="./Delete" asp-route-id="@item.Id">Delete</a>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <div class="alert alert-info">
        No courses match your filters.
    </div>
}

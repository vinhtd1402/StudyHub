@page
@model StudyHub.Pages.Credits.MomoReturnModel

@{
    ViewData["Title"] = "MoMo Payment Result";
}

<div class="container mt-5">

    <div class="card shadow-sm border-0">

        <div class="card-body p-5 text-center">

            <h1 class="fw-bold mb-3">
                @Model.StatusTitle
            </h1>

            <p class="text-muted mb-4">
                @Model.StatusMessage
            </p>

            <a asp-page="/Credits/Index"
               class="btn btn-primary">
                Back to My Credit
            </a>

        </div>

    </div>

</div>

@page
@model StudyHub.Pages.Credits.VietQrModel

@{
    ViewData["Title"] = "VietQR Payment";
}

<div class="container mt-4">

    <div class="row justify-content-center">

        <div class="col-lg-7">

            <div class="card shadow-sm border-0">

                <div class="card-body p-4 p-md-5">

                    <div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-4">
                        <div>
                            <h1 class="h3 fw-bold mb-1">
                                Pay with VietQR
                            </h1>
                            <p class="text-muted mb-0">
                                Scan the QR code and keep the transfer content unchanged.
                            </p>
                        </div>

                        <span class="badge bg-secondary">
                            @Model.Transaction.Status
                        </span>
                    </div>

                    <div class="text-center mb-4">
                        <img src="@Model.Transaction.PayUrl"
                             alt="VietQR payment code for @Model.Transaction.OrderId"
                             class="img-fluid border rounded"
                             style="max-width: 360px;" />
                    </div>

                    <dl class="row mb-4">
                        <dt class="col-sm-4">Bank</dt>
                        <dd class="col-sm-8">@Model.BankId</dd>

                        <dt class="col-sm-4">Account number</dt>
                        <dd class="col-sm-8">@Model.AccountNo</dd>

                        <dt class="col-sm-4">Amount</dt>
                        <dd class="col-sm-8 fw-semibold">@Model.Transaction.Amount.ToString("N0") VND</dd>

                        <dt class="col-sm-4">Transfer content</dt>
                        <dd class="col-sm-8 fw-semibold">@Model.Transaction.OrderId</dd>
                    </dl>

                    <div class="alert alert-warning mb-4" role="alert">
                        StudyHub records this VietQR transaction as pending. Add a bank webhook or admin confirmation flow before automatically adding credit to the wallet.
                    </div>

                    <a asp-page="/Credits/Index"
                       class="btn btn-primary w-100">
                        Back to My Credit
                    </a>

                </div>

            </div>

        </div>

    </div>

</div>

@page
@model StudyHub.Pages.Admin.CreditsModel

@{
    ViewData["Title"] = "Credit Approvals";
}

<div class="container mt-4">

    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
        <div>
            <h1 class="fw-bold mb-1">Credit Approvals</h1>
            <p class="text-muted mb-0">Review VietQR transfers and add credit to student or teacher wallets.</p>
        </div>

        <a asp-page="/Admin/Teachers" class="btn btn-outline-secondary">Teachers</a>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="alert alert-success" role="alert">
            @Model.StatusMessage
        </div>
    }

    <form method="get" class="row g-2 mb-4">
        <div class="col-md-4">
            <select asp-for="RoleFilter" class="form-select">
                <option value="">All users</option>
                <option value="Student">Students</option>
                <option value="Teacher">Teachers</option>
            </select>
        </div>

        <div class="col-md-4">
            <select asp-for="StatusFilter" class="form-select">
                <option value="">All statuses</option>
                <option value="@CreditTransactionStatus.Pending">Pending</option>
                <option value="@CreditTransactionStatus.Paid">Paid</option>
                <option value="@CreditTransactionStatus.Failed">Failed</option>
            </select>
        </div>

        <div class="col-md-4 d-flex gap-2">
            <button type="submit" class="btn btn-primary">Filter</button>
            <a asp-page="/Admin/Credits" class="btn btn-outline-secondary">Clear</a>
        </div>
    </form>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            @if (Model.Transactions.Any())
            {
                <div class="table-responsive">
                    <table class="table align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Order</th>
                                <th>User</th>
                                <th>Amount</th>
                                <th>Status</th>
                                <th>Created</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var transaction in Model.Transactions)
                            {
                                <tr>
                                    <td>@transaction.OrderId</td>
                                    <td>
                                        <div class="fw-semibold">@transaction.User?.FullName</div>
                                        <div class="text-muted small">@transaction.User?.Email</div>
                                    </td>
                                    <td>@transaction.Amount.ToString("N0") VND</td>
                                    <td>
                                        <span class="badge @(transaction.Status == CreditTransactionStatus.Paid ? "bg-success" : transaction.Status == CreditTransactionStatus.Failed ? "bg-danger" : "bg-secondary")">
                                            @transaction.Status
                                        </span>
                                    </td>
                                    <td>@transaction.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                                    <td class="text-end">
                                        @if (transaction.Status == CreditTransactionStatus.Pending)
                                        {
                                            <form method="post" class="d-inline" asp-page-handler="Approve" asp-route-id="@transaction.Id">
                                                <input type="hidden" asp-for="RoleFilter" />
                                                <input type="hidden" asp-for="StatusFilter" />
                                                <button type="submit" class="btn btn-sm btn-success">Approve</button>
                                            </form>

                                            <form method="post" class="d-inline" asp-page-handler="Reject" asp-route-id="@transaction.Id">
                                                <input type="hidden" asp-for="RoleFilter" />
                                                <input type="hidden" asp-for="StatusFilter" />
                                                <button type="submit" class="btn btn-sm btn-outline-danger">Reject</button>
                                            </form>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="p-5 text-center text-muted">
                    No VietQR transactions match the current filters.
                </div>
            }
        </div>
    </div>

</div>

@page
@model StudyHub.Pages.Admin.TeachersModel

@{
    ViewData["Title"] = "Teachers";
}

<div class="container mt-5">

    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">

        <div>

            <h1 class="fw-bold mb-1">
                Teachers
            </h1>

            <p class="text-muted mb-0">
                Manage teacher accounts for StudyHub
            </p>

        </div>

        <a class="btn btn-primary rounded-3"
           asp-page="/Admin/CreateTeacher">

            Create Teacher

        </a>

    </div>

    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="alert alert-success" role="alert">
            @Model.StatusMessage
        </div>
    }

    <div class="card shadow-sm border-0 rounded-4">

        <div class="card-body p-0">

            @if (Model.Teachers.Any())
            {
                <div class="table-responsive">

                    <table class="table align-middle mb-0">

                        <thead class="table-light">

                            <tr>

                                <th scope="col">
                                    Full Name
                                </th>

                                <th scope="col">
                                    Email
                                </th>

                                <th scope="col">
                                    Phone
                                </th>

                            </tr>

                        </thead>

                        <tbody>

                            @foreach (var teacher in Model.Teachers)
                            {
                                <tr>

                                    <td>
                                        @teacher.FullName
                                    </td>

                                    <td>
                                        @teacher.Email
                                    </td>

                                    <td>
                                        @(string.IsNullOrWhiteSpace(teacher.PhoneNumber) ? "-" : teacher.PhoneNumber)
                                    </td>

                                </tr>
                            }

                        </tbody>

                    </table>

                </div>
            }
            else
            {
                <div class="p-5 text-center">

                    <h2 class="h5 fw-semibold">
                        No teachers yet
                    </h2>

                    <p class="text-muted mb-4">
                        Create the first teacher account to start building courses.
                    </p>

                    <a class="btn btn-primary rounded-3"
                       asp-page="/Admin/CreateTeacher">

                        Create Teacher

                    </a>

                </div>
            }

        </div>

    </div>

</div>
